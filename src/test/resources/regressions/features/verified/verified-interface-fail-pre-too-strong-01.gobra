package pkg

// An implementation whose precondition is stronger than the interface
// specification violates Liskov substitutability. The generated subtype-proof
// method tries to call the implementation under the interface's weaker
// precondition; the call site violates the implementation's precondition.

type Adder interface {
	requires x > 0
	ensures  ret == x + 1
	decreases
	verified
	Add(x int) (ret int)
}

type StrictAdder struct{}

//:: ExpectedOutput(generated_implementation_proof:precondition_error)
requires x > 100
ensures  ret == x + 1
decreases
verified
func (s StrictAdder) Add(x int) (ret int) {
	ret = x + 1
	return ret
}

StrictAdder implements Adder
