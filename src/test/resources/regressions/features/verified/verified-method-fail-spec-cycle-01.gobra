package pkg

// Two verified methods that reference each other only in their postconditions
// (no body calls) form a spec-level cycle.

type Pair struct{ a, b int }

requires p.a >= 0
ensures ret == p.pingM()
decreases
verified
func (p Pair) pongM() (ret int) {
	ret = p.a  // body does NOT call pingM
	return ret
}

//:: ExpectedOutput(type_error)
requires p.b >= 0
ensures ret == p.pongM()
decreases
verified
func (p Pair) pingM() (ret int) {
	ret = p.b  // body does NOT call pongM
	return ret
}
