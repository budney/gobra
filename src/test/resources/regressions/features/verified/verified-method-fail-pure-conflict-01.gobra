package pkg

// A method annotated with both pure and verified is a type error.
// pure and verified are mutually exclusive.

type Val struct{ x int }

//:: ExpectedOutput(type_error)
pure
ensures ret == v.x
decreases
verified
func (v Val) readPure() (ret int) {
	return v.x
}
