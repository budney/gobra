package pkg

// A method annotated with both trusted and verified is a type error.
// trusted bypasses verification; verified requires it — they are mutually exclusive.

type Src struct{ x int }

//:: ExpectedOutput(type_error)
trusted
ensures ret == s.x
decreases
verified
func (s Src) readTrusted() (ret int) {
	ret = s.x
	return ret
}
