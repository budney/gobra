package pkg

// A verified function that uses old(...) in its postcondition is a type error
// because domain axioms cannot encode state snapshots.

//:: ExpectedOutput(type_error)
ensures ret == old(x) + 1
decreases
verified
func usesOldInPost(x int) (ret int) {
	ret = x + 1
	return ret
}
