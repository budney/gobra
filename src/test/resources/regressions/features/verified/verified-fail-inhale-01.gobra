package pkg

// A verified function that contains an inhale statement is a type error.
// inhale adds assertions to the proof state without verification, exactly as
// assume does. Both undermine the "earned" axiom guarantee of verified.

requires x > 0
ensures ret == 42
decreases
verified
func withInhale(x int) (ret int) {
	ret = x
	//:: ExpectedOutput(type_error)
	inhale ret == 42
	return ret
}
