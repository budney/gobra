package pkg

// One verified function used in the specs of multiple independent callers.
// Confirms the domain is globally visible, not scoped to a single method.

requires x >= 0
ensures ret == x + 10
decreases
verified
func addTen(x int) (ret int) {
	ret = x + 10
	return ret
}

requires a >= 0 && addTen(a) > 15
ensures result > 15
func callerA(a int) (result int) {
	result = addTen(a)
	return result
}

requires b >= 0 && addTen(b) < 100
ensures result < 100
func callerB(b int) (result int) {
	result = addTen(b)
	return result
}

requires c >= 0 && addTen(c) == 20
ensures result == 20
func callerC(c int) (result int) {
	result = addTen(c)
	return result
}
