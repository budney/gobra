package pkg

// Verified function used in another function's ensures clause (not just requires).

requires n >= 0
ensures ret == n * 3
decreases
verified
func triple(n int) (ret int) {
	ret = n + n + n
	return ret
}

// The caller's postcondition references triple — this goes through
// the postcondition assertion encoder, a different path than requires.
requires n >= 0
ensures result == triple(n)
func computeTriple(n int) (result int) {
	result = triple(n)
	return result
}

// Also use triple in both requires and ensures of the same function.
requires n >= 0 && triple(n) > 0
ensures result == triple(n) && result > 0
func triplePositive(n int) (result int) {
	result = triple(n)
	return result
}
