package pkg

// A verified method with multiple return values is a type error (v1 restriction).
// The domain encoding only supports a single return value.

type Pair struct{ x int }

//:: ExpectedOutput(type_error)
ensures a == p.x + 1 && b == p.x - 1
decreases
verified
func (p Pair) split() (a int, b int) {
	a = p.x + 1
	b = p.x - 1
	return a, b
}
