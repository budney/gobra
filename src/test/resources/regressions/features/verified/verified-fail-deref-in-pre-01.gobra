package pkg

// A verified function whose precondition dereferences a pointer is a type
// error. The precondition forms the antecedent of the domain axiom.
// Viper domain axioms cannot contain heap accesses, including pointer
// dereferences (*ptr), which require heap state to evaluate.

//:: ExpectedOutput(type_error)
requires *ptr >= 0
ensures ret >= 0
decreases
verified
func readPtrPre(ptr *int) (ret int) {
	ret = *ptr + 1
	return ret
}
