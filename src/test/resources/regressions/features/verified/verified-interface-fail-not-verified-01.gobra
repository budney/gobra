package pkg

// An implementation of a verified interface method that is not itself verified
// must be rejected with a clear error message.

type Adder interface {
	ensures  ret == x + 1
	decreases
	verified
	Add(x int) (ret int)
}

type BadAdder struct{}

//:: ExpectedOutput(type_error)
ensures ret == x + 1
func (b BadAdder) Add(x int) (ret int) {
	ret = x + 1
	return ret
}

BadAdder implements Adder
