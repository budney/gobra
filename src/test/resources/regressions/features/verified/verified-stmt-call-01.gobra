package pkg

// A verified function called as a plain statement (return value discarded).
// Previously, statement-level calls were silently encoded as domain-function
// applications and the Viper method body was never executed. Now they are
// encoded as real method calls so the body runs and postconditions are checked.

requires x >= 0
ensures ret == x + 1
decreases
verified
func increment(x int) (ret int) {
	ret = x + 1
	return ret
}

// Calling increment as a statement — result is discarded but the call executes.
// The ensures of the caller is provable only if the method body runs.
requires n >= 0
ensures result >= 0
func callAsStmt(n int) (result int) {
	increment(n) // called for its side-effect; return value intentionally ignored
	result = n
	return result
}
