package pkg

// A verified function with old() in an ensures clause is a type error.
// The postcondition is promoted verbatim to the body of a Viper domain axiom.
// Viper domain axioms cannot contain state-snapshotting operators such as old().

ensures ret == x + 1
//:: ExpectedOutput(type_error)
ensures old(x) >= 0
decreases
verified
func withOldInEnsures(x int) (ret int) {
	ret = x + 1
	return ret
}
