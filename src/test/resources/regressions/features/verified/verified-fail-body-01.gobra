package pkg

// The body does not satisfy the postcondition — Gobra should report an error.

requires x > 0
//:: ExpectedOutput(postcondition_error:assertion_error)
ensures ret == x + 2
decreases
verified
func badIncrement(x int) (ret int) {
	ret = x + 1  // wrong: should be x + 2
	return ret
}
