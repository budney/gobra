package pkg

// Mutually recursive verified functions form a cycle — type error.

ensures ret == x
decreases
verified
func cyclicA(x int) (ret int) {
	ret = cyclicB(x)
	return ret
}

//:: ExpectedOutput(type_error)
ensures ret == x
decreases
verified
func cyclicB(x int) (ret int) {
	ret = cyclicA(x)
	return ret
}
