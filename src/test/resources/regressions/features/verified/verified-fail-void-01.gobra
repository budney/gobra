package pkg

// A verified function with no return value is a type error.
// The postcondition is promoted to a Viper domain axiom whose conclusion
// must be an expression over the return value.  Void functions would
// produce a dead axiom (the trigger can never fire because void functions
// cannot appear in spec expressions) and are therefore not meaningful as
// verified.

//:: ExpectedOutput(type_error)
requires x > 0
ensures  x + 1 > 0
decreases
verified
func voidVerified(x int) {}
