package pkg

// A verified method with multiple return values — now supported via tuple encoding.

type Pair struct{ x int }

ensures a == p.x + 1 && b == p.x - 1
decreases
verified
func (p Pair) split() (a int, b int) {
	a = p.x + 1
	b = p.x - 1
	return a, b
}
