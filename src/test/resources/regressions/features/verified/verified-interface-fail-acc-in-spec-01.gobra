package pkg

// A verified interface method with acc(...) in its spec is a type error.
// Domain axioms cannot contain resource assertions.

type Cell struct{ v int }

type Reader interface {
	//:: ExpectedOutput(type_error)
	requires acc(p.v)
	ensures  ret == p.v
	decreases
	verified
	ReadV(p *Cell) (ret int)
}
