package pkg

// A function annotated with both trusted and verified is a type error.
// trusted bypasses verification; verified requires it — they are mutually exclusive.

//:: ExpectedOutput(type_error)
trusted
ensures ret == x + 1
decreases
verified
func trustedAndVerified(x int) (ret int) {
	ret = x + 1
	return ret
}
