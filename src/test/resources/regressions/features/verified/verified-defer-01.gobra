package pkg

// Verified functions can be used in defer statements.
// Previously, defer verifiedFunc() was rejected by the type-checker.
// Now it is allowed because verified functions are encoded as method calls
// in code context, and method calls are deferrable.

requires x >= 0
ensures ret == x + 1
decreases
verified
func increment(x int) (ret int) {
	ret = x + 1
	return ret
}

requires n >= 0
func deferIncrement(n int) {
	defer increment(n)
}
