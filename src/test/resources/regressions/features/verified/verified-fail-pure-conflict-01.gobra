package pkg

// A function annotated with both pure and verified is a type error.
// pure requires a single-expression body; verified requires a provable body
// and promotes postconditions to domain axioms — the two are incompatible.

//:: ExpectedOutput(type_error)
pure
ensures ret == x + 1
decreases
verified
func pureAndVerified(x int) (ret int) {
	return x + 1
}
